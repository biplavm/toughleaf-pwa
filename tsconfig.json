{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@toughleaf/platform-sdk": ["./vendor/@toughleaf/platform-sdk/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/pwa"]
}
