# Tough Leaf API backend
#
# PUBLIC_TOUGHLEAF_BACKEND — used by the Vite dev-server proxy to route /api/* requests.
# Default: http://localhost:8080
PUBLIC_TOUGHLEAF_BACKEND=http://localhost:8080

# SDK client base URL (overrides the Vite proxy path /api/v1).
# Set to a full URL to bypass the proxy (e.g. staging, production).
# Leave unset to use the proxy path (recommended for local dev).
#
# VITE_PUBLIC_TOUGHLEAF_BACKEND=http://localhost:8080
# VITE_TL_API_BASE=https://staging.example/api/v1

# Do not commit credentials. Demo accounts stay outside .env.
